#!/usr/bin/env bash
# eval/hooks/pre-commit — Hook git pré-commit pour l'évaluation des fiches wiki.
#
# Ce hook tourne automatiquement a chaque commit qui modifie des fiches wiki.
# Il execute Tier 1 (structurel), Tier 2 (semantique LLM) et la verification
# reseau (resolution DOI + URLs) sans interaction — le flag --external est
# toujours actif en mode git.
#
# Pour une verification manuelle sans --external (prompt interactif) :
#   python LLM-wiki-Assessment/eval/run_eval.py wiki/...fiche.md
#
# Installation :
#   python LLM-wiki-Assessment/eval/install_hook.py
# ou manuellement :
#   cp LLM-wiki-Assessment/eval/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -euo pipefail

export PYTHONIOENCODING=utf-8

META_PATTERN="(index|log|overview|glossary|eval_queue)\.md$"

STAGED=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E "^wiki/.*\.md$" \
  | grep -Ev "$META_PATTERN" \
  || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

echo ""
echo "Eval -- verification des fiches wiki modifiees (Tier 1 + Tier 2 + reseau)..."

FAILED=0
for FILE in $STAGED; do
  if ! python LLM-wiki-Assessment/eval/run_eval.py "$FILE" --external; then
    FAILED=1
  fi
done

echo ""
if [ "$FAILED" -ne 0 ]; then
  echo "BLOQUE -- Tier 1 echoue sur au moins une fiche."
  echo "   Corrige les erreurs ci-dessus puis recommite."
  exit 1
fi

echo "OK -- Toutes les fiches ont passe Tier 1 + verification reseau."
exit 0
